{
  "name": "medium-model",
  "model": {
    "block_size": 128,
    "n_embed": 192,
    "n_head": 6,
    "n_layer": 6,
    "dropout": 0.1
  },
  "train": {
    "batch_size": 64,
    "max_iterations": 15000,
    "eval_interval": 300,
    "learning_rate": 3e-4
  },
  "tokenizer": {
    "vocab_size": 10000,
    "tokenizer_path": "medium_model_tokenizer.json"
  }
}