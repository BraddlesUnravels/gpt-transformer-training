{
  "name": "small-model",
  "model": {
    "block_size": 128,
    "n_embed": 128,
    "n_head": 4,
    "n_layer": 4,
    "dropout": 0.1
  },
  "train": {
    "batch_size": 64,
    "max_iterations": 10000,
    "eval_interval": 200,
    "learning_rate": 5e-4
  },
  "tokenizer": {
    "vocab_size": 10000,
    "tokenizer_path": "small_model_tokenizer.json"
  }
}